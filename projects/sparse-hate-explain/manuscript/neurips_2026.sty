% neurips_2026.sty - Style file for NeurIPS 2026 submissions
% Simplified stub based on standard NeurIPS formatting

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/15 NeurIPS 2026 submission style]

% Page geometry
\RequirePackage[
  textwidth=5.5in,
  textheight=9in,
  top=1in,
  left=1.5in
]{geometry}

% Typography
\RequirePackage{times}
\RequirePackage{microtype}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Title and author formatting
\RequirePackage{authblk}

% Line numbers for review
\newif\if@neurips@final
\DeclareOption{final}{\@neurips@finaltrue}
\DeclareOption{preprint}{}
\ProcessOptions\relax

% Line numbers disabled for clean output
% Pass [final] option or uncomment lineno for review mode
% \if@neurips@final\else
%   \RequirePackage{lineno}
%   \linenumbers
% \fi

% Footnote for equal contribution
\newcommand{\equalcontrib}{\footnotemark[1]}

% Running title
\newcommand{\runningtitle}[1]{}
\newcommand{\runningauthor}[1]{}

\endinput
