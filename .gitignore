# Claude Configuration Git Ignore

# System files
.DS_Store
Thumbs.db

# Sensitive and local configuration
.env
.env.local
.mcp.json
settings*.json
settings*.json.bak
*.backup
.git-credentials

# History and session data
history.jsonl
session-env/
shell-snapshots/
file-history/
.claude/

# Cache and temporary files
cache/
debug/
downloads/
ide/
paste-cache/
todos/
logs/slurm/

# Telemetry and statistics
telemetry/
stats-cache.json
statsig/

# Pipeline runtime state (generated by /run-pipeline)
pipeline-state.json

# Project directory rules
projects/*/data/**
!projects/*/data/.gitkeep
projects/*/results/checkpoints/
projects/*/outputs/
projects/*/logs/
!projects/*/docs/
!projects/*/manuscript/

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
dist/
build/

# ML artifacts (large files)
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
outputs/

# Temporary working files
plan/
plans/
temp/
tasks/
teams/
